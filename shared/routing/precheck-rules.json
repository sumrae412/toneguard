{
  "version": 1,
  "local_pass_max_words": 4,
  "local_pass_phrases": [
    "sounds good",
    "thanks",
    "thank you",
    "got it",
    "ok",
    "okay",
    "will do"
  ],
  "escalation_phrases": [
    "what the heck",
    "what the hell",
    "are you serious",
    "i can't believe",
    "per my last email",
    "as i already said",
    "why this is so hard"
  ],
  "high_stakes_intent_modes": ["deescalating", "boundary"],
  "routes": ["local_pass", "standard", "deep", "blocked_error"]
}
